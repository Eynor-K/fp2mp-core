# === LLM Provider ===
LLM_PROVIDER=openrouter          # openrouter | anthropic

# --- OpenRouter (used when LLM_PROVIDER=openrouter) ---
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Anthropic direct (used when LLM_PROVIDER=anthropic) ---
# Если задан ANTHROPIC_API_KEY — Mediator и Critic автоматически используют
# Anthropic SDK с extended thinking, даже когда LLM_PROVIDER=openrouter.
# Это оптимальная конфигурация: дешёвые агенты через OpenRouter + глубокий
# анализ через Anthropic для синтеза и критики.
ANTHROPIC_API_KEY=sk-ant-...

# === Tools ===
TAVILY_API_KEY=tvly-...
E2B_API_KEY=e2b_...              # optional — code execution sandbox

# === Models ===
# MODEL_DEFAULT — лёгкая модель для ReAct-агентов (Web, Normative, Code, Orchestrator).
# gpt-4o-mini дёшев и достаточен для поиска и структурированных задач.
MODEL_DEFAULT=openai/gpt-4o-mini

# MODEL_THINKING — модель для Mediator и Critic. Эти агенты делают глубокий синтез
# из 10+ источников и принимают решение STOP/CONTINUE. Нужна мощная модель.
# Рекомендуется: anthropic/claude-3.5-sonnet (доступен через OpenRouter)
# или openai/gpt-4o (значительно лучше mini для многошагового рассуждения).
# НЕ рекомендуется использовать gpt-4o-mini для MODEL_THINKING.
MODEL_THINKING=anthropic/claude-3.5-sonnet

# === System settings ===
MAX_ITERATIONS=6
WIKI_PERSIST_DIR=
NORMATIVE_DB_PATH=data/normative
LOG_LEVEL=INFO
